export VECTOR_STORE_TYPE="milvus"
# milvus vector store
export MILVUS_ADDR="milvus:19530"
export MILVUS_USER=""
export MILVUS_PASSWORD=""
export MILVUS_TOKEN=""
# coze-milvus 容器用上方 MinIO 变量连对象存储（见 MINIO_ENDPOINT）。常见故障:
# - 仍写 minio:9000 但未启用 compose 内置 MinIO → 解析失败，改外部地址或 --profile local-minio
