# Docker Compose 会用本文件做 yml 里的 ${变量} 替换；该项只认「KEY=value」，不认「export KEY=…」。
# 若只写 export MINIO_ENDPOINT=…，插值仍为空，Milvus 会退回默认 minio:9000，日志出现 lookup minio: no such host。
# 以下凡被 compose 引用的变量已用无 export 形式；其余仍可用 export 供 shell source。
#
# Server
export LISTEN_ADDR=":8888"
export LOG_LEVEL="debug"
export MAX_REQUEST_BODY_SIZE=1073741824
export SERVER_HOST="http://localhost${LISTEN_ADDR}"
export USE_SSL="0"
export SSL_CERT_FILE=""
export SSL_KEY_FILE=""
# USE_SSL / SSL_*：由后端 main.go 读取，仅当「Hertz 在 LISTEN_ADDR 上直接启 HTTPS」时生效（USE_SSL=1 且两路径为容器内 PEM）。
# 当前 Docker 推荐：TLS 在 Nginx（coze-web）或 SLB 终止，coze-server 仍监听明文 :8888，Nginx 反代用 http://coze-server:8888 → 请保持 USE_SSL=0，勿与 certbot/Let’s Encrypt 卷混用。
# 若确需进程内 TLS（例如去掉 Nginx、直连后端）：USE_SSL=1，并把证书挂进 coze-server 卷后在 SSL_* 中写绝对路径（如 /app/ssl/fullchain.pem）。
# 无 export：供 compose 映射宿主机端口，只能是「地址:端口」，不能写域名。
# 宿主机已有 Nginx 占用 80：不要与 coze-web 抢 80，设 WEB_LISTEN_ADDR=127.0.0.1:8888（仅本机反代），公网由「已有 Nginx」监听 80/443 并反代到 127.0.0.1:8888；示例见 docker/nginx/external/coze.zcat.cn.conf.example（勿把该文件挂进 coze-web）。
# 已有 Nginx 在 Docker 内时：把 coze-web 加入同一 Docker network，示例里 upstream 从 127.0.0.1:8888 改为 coze-web:80。
# ACME HTTP-01：若 80 在外层 Nginx，certbot 的 webroot 与校验路径需配在外层，或由外层把 /.well-known/ 反代到 coze-web（卷需可被 coze-web 读到）。
WEB_LISTEN_ADDR=0.0.0.0:8888
# 与 nginx server_name、certbot -d 一致；更换域名时请同步改 docker/nginx/conf.d/default.conf 中的 coze.zcat.cn
export COZE_DOMAIN="coze.zcat.cn"
# 首次 certbot 申请证书用（Let's Encrypt 注册邮箱）
export CERTBOT_EMAIL="hb@onecat.cn"
# HTTPS 生效后（与下方「方案」二选一）
# export SERVER_HOST="https://coze.zcat.cn"
# export STORAGE_UPLOAD_HTTP_SCHEME="https"
#
# —— 方案 A（推荐）：TLS 在「外层」Nginx 终止，证书用 certbot-conf 卷挂在外层容器（见 docker/nginx/external/coze.zcat.cn.conf.example）
#   不要给 coze-web 开 443、不要设 WEB_LISTEN_HTTPS；coze-web 仍只提供 HTTP（coze-web:80）。
#   改好 SERVER_HOST / STORAGE_UPLOAD_HTTP_SCHEME 后 up -d coze-server（或整栈）即可。
#   续期后 reload「外层」nginx：docker exec <外层容器> nginx -s reload（certbot 在 coze 栈内 renew 即可）。
#
# —— 方案 B：TLS 在 coze-web 内终止（无外层或外层只做 TCP）
#   WEB_LISTEN_HTTPS=0.0.0.0:443；取消 docker/nginx/conf.d/default.conf 里 443 段注释；compose 映射 443；然后 force-recreate coze-web。
#   续期后：docker compose exec coze-web nginx -s reload
#
# ACME（compose 已含 certbot 与 certbot-www / certbot-conf 卷；续期容器每 12h 执行 certbot renew）
# HTTP-01：① DNS A 记录；② 安全组放行 80（及方案 B 时 443）；③ 外层或 coze-web 能访问 webroot / 反代 /.well-known/；
# ④ docker compose up -d coze-web certbot（或 up -d）；⑤ 首次申请：
# docker compose run --rm --entrypoint certbot certbot certonly --webroot -w /var/www/certbot -d coze.zcat.cn --email "${CERTBOT_EMAIL}" --agree-tos --non-interactive
# 手动 PEM 仍可用 docker/nginx/ssl/ 方式，不必跑 certbot。

# MySQL
# 使用 docker compose 内置 MySQL 时: docker compose --profile local-mysql up -d，且 MYSQL_HOST=mysql
# 使用外部 MySQL 时: 将 MYSQL_HOST 设为容器可访问的地址（如云库内网、宿主机: host.docker.internal）
export MYSQL_ROOT_PASSWORD=root
export MYSQL_DATABASE=opencoze
export MYSQL_USER=coze
export MYSQL_PASSWORD=coze123
export MYSQL_HOST=mysql
export MYSQL_PORT=3306
export MYSQL_DSN="${MYSQL_USER}:${MYSQL_PASSWORD}@tcp(${MYSQL_HOST}:${MYSQL_PORT})/${MYSQL_DATABASE}?charset=utf8mb4&parseTime=True"
export ATLAS_URL="mysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DATABASE}?charset=utf8mb4&parseTime=True"
export MYSQL_MAX_IDLE_CONNS=10
export MYSQL_MAX_OPEN_CONNS=100
export MYSQL_CONN_MAX_LIFETIME=3600      # seconds
export MYSQL_CONN_MAX_IDLE_TIME=600      # seconds

# Redis
export REDIS_AOF_ENABLED=no
export REDIS_IO_THREADS=4
export ALLOW_EMPTY_PASSWORD=yes
export REDIS_ADDR="redis:6379"
export REDIS_PASSWORD=""

# This Upload component used in Agent / workflow File/Image With LLM  , support the component of imagex / storage
# default: storage, use the settings of storage component
# if imagex, you must finish the configuration of <VolcEngine ImageX>
export FILE_UPLOAD_COMPONENT_TYPE="storage"

# VolcEngine ImageX
export VE_IMAGEX_AK=""
export VE_IMAGEX_SK=""
export VE_IMAGEX_SERVER_ID=""
export VE_IMAGEX_DOMAIN=""
export VE_IMAGEX_TEMPLATE=""
export VE_IMAGEX_UPLOAD_HOST="https://imagex.volcengineapi.com"

# Storage component
export STORAGE_TYPE="minio" # minio / tos / s3（阿里云 OSS 用 s3，勿填 tos；tos 仅对接火山引擎 TOS）
export STORAGE_UPLOAD_HTTP_SCHEME="http" # http / https. If coze studio website is https, you must set it to https
export STORAGE_BUCKET="opencoze"
# 应用上传：STORAGE_TYPE 可为 minio / tos / s3，不必用 MinIO 产品。
# Milvus 向量库：只要 VECTOR_STORE_TYPE=milvus，容器仍必须连一台 S3 兼容存储；Milvus 环境变量叫 MINIO_* 是历史命名，实际可填云厂商 S3 端点 + AK/SK（与 STORAGE_TYPE=s3 时常为同一套桶/凭证）。
# compose 内置 MinIO（可选）: --profile local-minio，且 MINIO_ENDPOINT=minio:9000
# 纯云 S3 / 阿里云 OSS：MINIO_ENDPOINT=区域 Endpoint 的 host:443（勿用 :9000，9000 是 MinIO 默认口，OSS 走 HTTPS 443）
# 例-阿里云内网（仅同地域 VPC 内 ECS）: MINIO_ENDPOINT=oss-cn-hangzhou-internal.aliyuncs.com:443
# 例-阿里云公网: MINIO_ENDPOINT=oss-cn-hangzhou.aliyuncs.com:443
# 此时 MINIO_USE_SSL=true；AK/SK 为 OSS 的 AccessKey；桶名仍用 MINIO_DEFAULT_BUCKETS，不要拼进 endpoint
# 若仍 i/o timeout：检查安全组/仅内网 endpoint 是否从当前网络可达，或改用公网 endpoint + 白名单
# 若日志 403 SecondLevelDomainForbidden / Please use virtual hosted style（且 useVirtualHost=false）：OSS 要求 virtual-hosted 访问。推荐设 MINIO_CLOUD_PROVIDER=aliyun（见 Milvus milvus.yaml 注释），并设 MINIO_REGION 与 Bucket 区域一致，例如 cn-hangzhou；也可改用 MINIO_USE_VIRTUAL_HOST=true
# 若日志 Access Denied（bucket=xxx）：RAM 中该 AK 对桶 xxx 无权限；至少需 oss:GetBucket、oss:ListObjects、oss:Put/Get/DeleteObject 等（或控制台对该桶授权给此子账号）
# 若服务跑在宿主机 MinIO: 可写 host.docker.internal:9000 且 MINIO_USE_SSL=false（Linux compose 已配 extra_hosts）
export MINIO_ROOT_USER=minioadmin
export MINIO_ROOT_PASSWORD=minioadmin123
export MINIO_DEFAULT_BUCKETS=milvus
export MINIO_AK=$MINIO_ROOT_USER
export MINIO_SK=$MINIO_ROOT_PASSWORD
# 无 export：compose 中 milvus 的 MINIO_ADDRESS=${MINIO_ENDPOINT:-minio:9000} 依赖此行；外部 MinIO 改为 内网IP:9000 或 host.docker.internal:9000
MINIO_ENDPOINT=minio:9000
export MINIO_API_HOST="http://${MINIO_ENDPOINT}"
# 无 export：compose 中 milvus 的 MINIO_USE_SSL 插值依赖此行
MINIO_USE_SSL=false
# Milvus 对象存储 cloud 模式；本地/自建 MinIO 保持 aws；阿里云 OSS 填 aliyun
MINIO_CLOUD_PROVIDER=aws
# 仅当不用 aliyun 模式且仍须强制 virtual host 时设为 true；一般 OSS 用上一行即可
MINIO_USE_VIRTUAL_HOST=false
# 与 Bucket 区域一致，如 cn-hangzhou；本地 MinIO 可留空
MINIO_REGION=

# TOS（仅火山引擎 TOS；TOS_ENDPOINT 形如 https://tos-cn-beijing.volces.com，勿填 oss-*.aliyuncs.com）
export TOS_ACCESS_KEY=
export TOS_SECRET_KEY=
export TOS_ENDPOINT=https://tos-cn-beijing.volces.com
export TOS_REGION=cn-beijing

# S3（含阿里云 OSS、AWS S3 等 S3 兼容存储；后端 UsePathStyle=false，即 virtual-hosted）
# 阿里云 OSS 示例：STORAGE_TYPE=s3，STORAGE_BUCKET=你的桶名，S3_REGION=cn-hangzhou，
# S3_ENDPOINT=https://oss-cn-hangzhou-internal.aliyuncs.com（或公网 https://oss-cn-hangzhou.aliyuncs.com，须带 https://，勿只写 host）
# 若出现 Head "//桶名./oss-..."、unsupported protocol scheme：多为未写 https:// 或误用 STORAGE_TYPE=tos
export S3_ACCESS_KEY=
export S3_SECRET_KEY=
export S3_ENDPOINT=
# 当前后端未读取此变量，可留空；桶名用 STORAGE_BUCKET，服务端点用 S3_ENDPOINT
export S3_BUCKET_ENDPOINT=
export S3_REGION=

# Elasticsearch
export ES_ADDR="http://elasticsearch:9200"
export ES_VERSION="v8"
export ES_USERNAME=""
export ES_PASSWORD=""
export ES_NUMBER_OF_SHARDS="1"
export ES_NUMBER_OF_REPLICAS="1"
# 内置 ES 容器 JVM。
# - exit 137：整机/容器内存不足，可略减堆或加 swap；compose 已设 ELASTICSEARCH_NODE_ROLES 去掉 ml。
# - OutOfMemoryError: Metaspace：元空间勿低于约 192m~256m（过小会启动失败 exit 3）。
# 宿主机约 8GB：推荐堆 512m + 元空间 256m（与 Milvus/Redis/系统等分摊）；2~4GB 机器可改为 -Xms256m -Xmx256m。
export ES_JAVA_OPTS="-Xms512m -Xmx512m -XX:MaxMetaspaceSize=256m"

# Backend Event Bus
export COZE_MQ_TYPE="nsq" # nsq / kafka / rmq / pulsar / nats
export MQ_NAME_SERVER="nsqd:4150"
# RocketMQ
export RMQ_ACCESS_KEY=""
export RMQ_SECRET_KEY=""
# Pulsar
# Use Pulsar as backend eventbus, MQ_NAME_SERVER example is: "pulsar:6650"
# Fill PULSAR_JWT_TOKEN for JWT auth, leave empty for no auth
export PULSAR_SERVICE_URL="pulsar://pulsar-service:6650"
export PULSAR_JWT_TOKEN=""
# NATS
# Use NATS as backend eventbus with JetStream support
# Set COZE_MQ_TYPE="nats" and MQ_NAME_SERVER="nats:4222" to enable NATS
# NATS_SERVER_URL: NATS server connection URL, supports nats:// and tls:// protocols
# For cluster setup, use comma-separated URLs: "nats://nats1:4222,nats://nats2:4222"
# For TLS connection: "tls://nats:4222"
export NATS_SERVER_URL="nats://nats:4222"
# NATS_JWT_TOKEN: JWT token for NATS authentication (leave empty for no auth)
export NATS_JWT_TOKEN=""
# NATS_NKEY_SEED: Path to NATS seed file for NKey authentication (optional)
export NATS_NKEY_SEED=""
# NATS_USERNAME: Username for NATS authentication (optional)
export NATS_USERNAME=""
# NATS_PASSWORD: Password for NATS authentication (optional)
export NATS_PASSWORD=""
# NATS_TOKEN: Token for NATS authentication (optional)
export NATS_TOKEN=""
# NATS_STREAM_REPLICAS: Number of replicas for JetStream streams (default: 1)
export NATS_STREAM_REPLICAS="1"
# NATS_USE_JETSTREAM: Enable JetStream mode for message persistence and reliability (default: false)
export NATS_USE_JETSTREAM="true"

# Settings for VectorStore
# VectorStore type: milvus / vikingdb / oceanbase
